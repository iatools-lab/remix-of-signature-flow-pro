// =====================================================================
// Usign — Schéma Prisma
// Plateforme interne de signature électronique
//
// Stack : PostgreSQL + Prisma
// Auth  : Email + mot de passe (bcrypt) — usage strictement interne
// RBAC  : Rôles globaux + appartenance à des groupes/départements
// Modules : Audit log, modèles de parapheurs, archivage externe (GED),
//           notifications & rappels programmés
//
// Conventions :
//   - Identifiants : cuid()
//   - Timestamps   : createdAt / updatedAt sur toutes les entités métier
//   - Soft delete  : deletedAt (nullable) là où il a un sens fonctionnel
//   - Money/temps  : DateTime en UTC, jamais de fuseau côté DB
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// ENUMS
// =====================================================================

/// Rôle global d'un utilisateur dans la plateforme.
/// - ADMIN   : administrateur technique (gestion des comptes, audit complet)
/// - MANAGER : responsable d'un ou plusieurs groupes (création de parapheurs,
///             supervision de l'équipe)
/// - USER    : collaborateur standard (création de parapheurs si autorisé,
///             signature, consultation)
enum UserRole {
  ADMIN
  MANAGER
  USER
}

/// Rôle d'un membre dans un groupe (département / équipe).
enum GroupRole {
  OWNER
  MANAGER
  MEMBER
}

/// Cycle de vie d'un parapheur.
enum BinderStatus {
  DRAFT      // En préparation, modifiable
  STARTED    // Diffusé aux signataires, non modifiable
  FINISHED   // Toutes les signatures sont apposées
  STOPPED    // Annulé manuellement avant complétion
  ARCHIVED   // Verrouillé, exporté vers GED
}

/// État d'un signataire pour un parapheur donné.
enum SignerStatus {
  PENDING
  SIGNED
  DECLINED
  EXPIRED
}

/// Méthode utilisée par un signataire pour produire sa signature.
enum SignatureMethod {
  DRAWN
  TYPED
  IMAGE
  OTP
}

/// Catégorie d'un fichier rattaché à un parapheur.
enum FileKind {
  DOCUMENT     // À signer
  ATTACHMENT   // Pièce jointe (lecture seule)
  EVIDENCE     // Preuve générée (PDF signé, certificat, journal)
}

/// Canal d'une notification.
enum NotificationChannel {
  EMAIL
  IN_APP
}

/// État d'envoi d'une notification.
enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

/// Type d'événement de notification (utile pour templates et filtrage).
enum NotificationKind {
  BINDER_STARTED
  SIGNER_INVITED
  SIGNER_REMINDER
  SIGNER_SIGNED
  BINDER_COMPLETED
  BINDER_STOPPED
  BINDER_ARCHIVED
}

/// Catégories d'événements pour l'audit log.
enum AuditAction {
  // Auth
  USER_LOGIN
  USER_LOGOUT
  USER_LOGIN_FAILED
  USER_PASSWORD_CHANGED

  // Comptes
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  USER_ROLE_CHANGED

  // Groupes
  GROUP_CREATED
  GROUP_UPDATED
  GROUP_DELETED
  GROUP_MEMBER_ADDED
  GROUP_MEMBER_REMOVED

  // Parapheurs
  BINDER_CREATED
  BINDER_UPDATED
  BINDER_STARTED
  BINDER_SIGNED
  BINDER_COMPLETED
  BINDER_STOPPED
  BINDER_ARCHIVED
  BINDER_DELETED

  // Documents & zones
  DOCUMENT_ADDED
  DOCUMENT_REMOVED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
  SIGNATURE_FIELD_ADDED
  SIGNATURE_FIELD_REMOVED
  SIGNATURE_FIELD_UPDATED

  // Signataires
  SIGNER_ADDED
  SIGNER_REMOVED
  SIGNER_INVITED
  SIGNER_REMINDED

  // Templates
  TEMPLATE_CREATED
  TEMPLATE_UPDATED
  TEMPLATE_DELETED
  TEMPLATE_USED

  // Signature personnelle
  SAVED_SIGNATURE_CREATED
  SAVED_SIGNATURE_UPDATED
  SAVED_SIGNATURE_DELETED
  SAVED_SIGNATURE_USED

  // Archivage
  ARCHIVE_EXPORTED
  ARCHIVE_RESTORED
}

// =====================================================================
// COMPTES & AUTHENTIFICATION
// =====================================================================

/// Utilisateur interne de la plateforme.
/// Authentification par email + mot de passe haché (bcrypt côté application).
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerifiedAt DateTime?

  // Authentification
  passwordHash    String
  // Verrouillage de compte après tentatives infructueuses
  failedLoginAttempts Int     @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?

  // Profil
  firstName  String
  lastName   String
  /// Initiales calculées et stockées pour affichage rapide (ex. "JD")
  initials   String
  jobTitle   String?
  phone      String?
  avatarUrl  String?
  locale     String   @default("fr")
  timezone   String   @default("Europe/Paris")

  // RBAC global
  role       UserRole @default(USER)

  // État du compte
  isActive   Boolean  @default(true)
  deletedAt  DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  sessions          Session[]
  passwordResets    PasswordResetToken[]
  groupMemberships  GroupMembership[]
  ownedBinders      Binder[]              @relation("BinderOwner")
  createdBinders    Binder[]              @relation("BinderCreatedBy")
  signers           BinderSigner[]        @relation("SignerUser")
  notifications     Notification[]
  ownedTemplates    BinderTemplate[]      @relation("TemplateOwner")
  auditEvents       AuditEvent[]          @relation("AuditActor")
  savedSignature    SavedSignature?

  @@index([role, isActive])
  @@index([deletedAt])
}

/// Session de connexion active (cookie httpOnly côté serveur).
/// On stocke le hash du token, jamais le token lui-même.
model Session {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash   String   @unique
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?

  @@index([userId])
  @@index([expiresAt])
}

/// Jeton de réinitialisation de mot de passe.
model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?

  createdAt  DateTime @default(now())
  requestedFromIp String?

  @@index([userId])
  @@index([expiresAt])
}

// =====================================================================
// SIGNATURE PERSONNELLE RÉUTILISABLE
// =====================================================================

/// Signature préenregistrée par un utilisateur, réutilisée automatiquement
/// dans son inbox ("Tout signer en un clic"). Une seule par utilisateur.
/// La donnée brute (PNG dataURL ou texte typé) reste côté serveur ;
/// on stocke aussi un hash pour pouvoir auditer son usage.
model SavedSignature {
  id        String          @id @default(cuid())
  userId    String          @unique
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  method    SignatureMethod
  /// Données de signature (PNG base64, ou texte typé, ou clé du blob)
  data      String
  /// Hash SHA-256 de `data` — sert de preuve dans l'audit log
  sha256    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================================================================
// GROUPES / DÉPARTEMENTS
// =====================================================================

/// Groupe ou département (RH, Juridique, Achats, ...).
/// Sert à scoper les parapheurs et à délimiter les permissions.
model Group {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  memberships GroupMembership[]
  binders     Binder[]
  templates   BinderTemplate[]

  @@index([deletedAt])
}

/// Appartenance d'un utilisateur à un groupe, avec rôle local.
model GroupMembership {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId   String
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role      GroupRole @default(MEMBER)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, groupId])
  @@index([groupId])
}

// =====================================================================
// PARAPHEURS (BINDERS)
// =====================================================================

/// Un parapheur regroupe un ou plusieurs documents à signer par
/// une liste ordonnée de signataires.
model Binder {
  id          String       @id @default(cuid())
  name        String
  description String?

  // Propriété & traçabilité
  ownerId     String
  owner       User         @relation("BinderOwner", fields: [ownerId], references: [id])
  createdById String
  createdBy   User         @relation("BinderCreatedBy", fields: [createdById], references: [id])
  groupId     String?
  group       Group?       @relation(fields: [groupId], references: [id])

  // Origine éventuelle
  templateId  String?
  template    BinderTemplate? @relation(fields: [templateId], references: [id])

  // Cycle de vie
  status      BinderStatus @default(DRAFT)
  progress    Int          @default(0) // 0..100
  startedAt   DateTime?
  completedAt DateTime?
  stoppedAt   DateTime?
  stoppedReason String?

  // Options
  consolidation      Boolean @default(false)
  signersOrderStrict Boolean @default(false) // signature séquentielle obligatoire

  // Préférences de notification (au niveau du parapheur)
  notifyOnStart    Boolean @default(true)
  notifyOnComplete Boolean @default(true)
  remindersEnabled Boolean @default(false)
  reminderEveryHours Int?  // ex. 24, 48...

  // Échéance optionnelle (auto-expiration)
  expiresAt   DateTime?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  // Relations
  documents       BinderDocument[]
  attachments     BinderAttachment[]
  evidenceFiles   BinderEvidence[]
  signers         BinderSigner[]
  signatureFields SignatureField[]
  ccRecipients    BinderCcRecipient[]
  notifications   Notification[]
  archive         BinderArchive?
  auditEvents     AuditEvent[]      @relation("AuditBinder")

  @@index([ownerId, status])
  @@index([groupId, status])
  @@index([status, updatedAt])
  @@index([createdById])
  @@index([deletedAt])
}

/// Destinataire en copie (CC) d'un parapheur.
/// Distinct de User car peut être un email externe (rare en interne, mais utile).
model BinderCcRecipient {
  id        String  @id @default(cuid())
  binderId  String
  binder    Binder  @relation(fields: [binderId], references: [id], onDelete: Cascade)

  email     String
  name      String?

  createdAt DateTime @default(now())

  @@unique([binderId, email])
  @@index([binderId])
}

/// Document à signer.
model BinderDocument {
  id        String  @id @default(cuid())
  binderId  String
  binder    Binder  @relation(fields: [binderId], references: [id], onDelete: Cascade)

  name      String
  /// Référence vers le stockage objet (clé S3 / chemin GED)
  storageKey String
  mimeType   String  @default("application/pdf")
  sizeBytes  Int
  pages      Int     @default(1)
  /// Hash SHA-256 du fichier original — sert de preuve d'intégrité
  sha256     String
  /// Ordre d'affichage dans le parapheur
  position   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fields    SignatureField[]

  @@index([binderId, position])
}

/// Pièce jointe en lecture seule (annexe, conditions générales, etc.).
model BinderAttachment {
  id         String  @id @default(cuid())
  binderId   String
  binder     Binder  @relation(fields: [binderId], references: [id], onDelete: Cascade)

  name       String
  storageKey String
  mimeType   String
  sizeBytes  Int
  sha256     String

  createdAt  DateTime @default(now())

  @@index([binderId])
}

/// Fichier de preuve généré côté serveur (PDF signé final, certificat,
/// journal d'audit cristallisé). Toujours en lecture seule.
model BinderEvidence {
  id         String   @id @default(cuid())
  binderId   String
  binder     Binder   @relation(fields: [binderId], references: [id], onDelete: Cascade)

  kind       FileKind @default(EVIDENCE)
  name       String
  storageKey String
  mimeType   String
  sizeBytes  Int
  sha256     String

  createdAt  DateTime @default(now())

  @@index([binderId])
}

/// Signataire d'un parapheur. Peut référencer un utilisateur interne
/// (cas standard) ou un email externe ponctuel.
model BinderSigner {
  id         String        @id @default(cuid())
  binderId   String
  binder     Binder        @relation(fields: [binderId], references: [id], onDelete: Cascade)

  /// Lien optionnel vers un utilisateur interne
  userId     String?
  user       User?         @relation("SignerUser", fields: [userId], references: [id])

  /// Snapshot des informations au moment de l'invitation
  /// (immuable même si l'utilisateur est désactivé/supprimé ensuite)
  name       String
  email      String
  /// Couleur d'affichage dans l'éditeur de zones
  color      String?

  order      Int           @default(1)
  status     SignerStatus  @default(PENDING)

  signedAt   DateTime?
  signatureMethod SignatureMethod?
  /// URL ou clé du blob de signature (image PNG, ou texte typé)
  signatureData   String?

  /// Token d'invitation (hash). Le token brut n'est envoyé qu'une fois.
  inviteTokenHash String?  @unique
  inviteSentAt    DateTime?
  lastReminderAt  DateTime?

  /// Métadonnées de signature pour la preuve
  signedFromIp    String?
  signedUserAgent String?

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  fields     SignatureField[]

  @@unique([binderId, order])
  @@unique([binderId, email])
  @@index([binderId, status])
  @@index([userId])
}

/// Zone de signature positionnée sur une page d'un document.
/// Coordonnées normalisées (0..1) relatives à la taille de la page.
model SignatureField {
  id          String   @id @default(cuid())

  binderId    String
  binder      Binder   @relation(fields: [binderId], references: [id], onDelete: Cascade)

  documentId  String
  document    BinderDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  signerId    String
  signer      BinderSigner   @relation(fields: [signerId], references: [id], onDelete: Cascade)

  page        Int      // 1-based
  x           Float    // 0..1
  y           Float    // 0..1
  width       Float    // 0..1
  height      Float    // 0..1

  /// Une fois signée, on fige les données ici (redondance volontaire avec
  /// BinderSigner pour faciliter la génération du PDF final).
  signedAt       DateTime?
  signatureData  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([binderId, page])
  @@index([documentId, page])
  @@index([signerId])
}

// =====================================================================
// MODÈLES DE PARAPHEURS (TEMPLATES RÉUTILISABLES)
// =====================================================================

/// Modèle réutilisable : pré-remplit nom, options, signataires types et
/// éventuellement des documents standards.
model BinderTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?

  ownerId     String
  owner       User     @relation("TemplateOwner", fields: [ownerId], references: [id])
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id])

  /// Visible par tout le monde dans l'entreprise (true) ou réservé au groupe (false)
  isShared    Boolean  @default(false)

  // Options par défaut, copiées sur le parapheur créé depuis ce template.
  defaultConsolidation      Boolean @default(false)
  defaultSignersOrderStrict Boolean @default(false)
  defaultNotifyOnStart      Boolean @default(true)
  defaultNotifyOnComplete   Boolean @default(true)
  defaultRemindersEnabled   Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  documents   BinderTemplateDocument[]
  signers     BinderTemplateSigner[]
  fields      BinderTemplateField[]
  binders     Binder[]

  @@index([ownerId])
  @@index([groupId])
  @@index([deletedAt])
}

/// Document standard d'un template (PDF type, mentions légales...).
model BinderTemplateDocument {
  id         String   @id @default(cuid())
  templateId String
  template   BinderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  name       String
  storageKey String
  mimeType   String   @default("application/pdf")
  sizeBytes  Int
  pages      Int      @default(1)
  sha256     String
  position   Int      @default(0)

  fields     BinderTemplateField[]

  @@index([templateId, position])
}

/// Signataire type (rôle) défini dans un template (ex. "Acheteur", "DAF").
model BinderTemplateSigner {
  id         String   @id @default(cuid())
  templateId String
  template   BinderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  /// Libellé du rôle, ex. "Responsable RH"
  roleLabel  String
  order      Int      @default(1)
  color      String?

  fields     BinderTemplateField[]

  @@unique([templateId, order])
  @@index([templateId])
}

/// Zones de signature pré-positionnées dans un template.
model BinderTemplateField {
  id          String   @id @default(cuid())
  templateId  String
  template    BinderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  documentId  String
  document    BinderTemplateDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  signerId    String
  signer      BinderTemplateSigner   @relation(fields: [signerId], references: [id], onDelete: Cascade)

  page        Int
  x           Float
  y           Float
  width       Float
  height      Float

  @@index([templateId])
  @@index([documentId, page])
}

// =====================================================================
// ARCHIVAGE EXTERNE / GED
// =====================================================================

/// Trace d'un export d'un parapheur terminé vers un système GED externe.
/// Un parapheur archivé a exactement une entrée ici.
model BinderArchive {
  id            String   @id @default(cuid())
  binderId      String   @unique
  binder        Binder   @relation(fields: [binderId], references: [id], onDelete: Cascade)

  /// Nom du système cible (ex. "GED-Acme", "Iron Mountain", "Local NAS")
  targetSystem  String
  /// Référence externe renvoyée par la GED
  externalRef   String
  /// URL de consultation côté GED (si exposée)
  externalUrl   String?

  exportedAt    DateTime @default(now())
  exportedById  String?
  /// Hash du paquet exporté (zip + manifeste) — preuve d'intégrité
  packageSha256 String

  /// Date de purge/destruction prévue, si politique de rétention
  retentionUntil DateTime?

  @@index([targetSystem])
  @@index([retentionUntil])
}

// =====================================================================
// NOTIFICATIONS & RAPPELS
// =====================================================================

/// File de notifications (email, in-app). Programmable dans le futur
/// via scheduledFor pour les rappels.
model Notification {
  id         String              @id @default(cuid())

  channel    NotificationChannel
  kind       NotificationKind
  status     NotificationStatus  @default(PENDING)

  /// Destinataire interne (si applicable)
  userId     String?
  user       User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// Destinataire externe (signataire non-utilisateur, CC externe)
  toEmail    String?
  toName     String?

  /// Contexte
  binderId   String?
  binder     Binder?             @relation(fields: [binderId], references: [id], onDelete: Cascade)
  signerId   String?

  /// Contenu (peut être généré à l'envoi à partir d'un template)
  subject    String?
  bodyText   String?
  bodyHtml   String?

  /// Programmation
  scheduledFor DateTime          @default(now())
  sentAt       DateTime?
  failedAt     DateTime?
  attempts     Int               @default(0)
  lastError    String?

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status, scheduledFor])
  @@index([binderId])
  @@index([userId])
}

// =====================================================================
// AUDIT LOG
// =====================================================================

/// Journal d'audit immuable.
/// Toute action significative écrite ici. Aucune mise à jour ni suppression
/// n'est attendue (à enforcer via politique applicative ou trigger Postgres).
model AuditEvent {
  id         String      @id @default(cuid())

  action     AuditAction
  /// Acteur (utilisateur connecté). Nullable pour les actions système.
  actorId    String?
  actor      User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorEmail String?     // snapshot
  actorIp    String?
  actorUserAgent String?

  /// Type d'entité ciblée ("Binder", "User", "Group"...) — texte libre pour
  /// rester souple si on ajoute de nouvelles entités.
  entityType String
  entityId   String

  /// Lien fort optionnel vers les entités les plus consultées
  binderId   String?
  binder     Binder?     @relation("AuditBinder", fields: [binderId], references: [id], onDelete: SetNull)

  /// Diff ou contexte structuré (avant/après, métadonnées)
  metadata   Json?

  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@index([binderId, createdAt])
  @@index([action, createdAt])
}
